<?xml version="1.0"?>
<plugin id="cordova-plugin-google-tag-manager" version="0.1.0"
    xmlns="http://apache.org/cordova/ns/plugins/1.0">
    <name>GoogleTagManager</name>
    <js-module src="www/TagManager.js" name="TagManager">
        <clobbers target="TagManager" />
    </js-module>
    <platform name="android">
        <config-file target="res/xml/config.xml" parent="/*">
            <feature name="TagManager">
                <param name="android-package" value="com.productleague.TagManagerPlugin"/>
            </feature>
        </config-file>
        <framework src="com.google.android.gms:play-services-tagmanager:18.1.1" />
        <resource-file src="resources/container/GTM-KLBN64W6.json" target="src/main/assets/container/GTM-KLBN64W6.json" />
    </platform>
    <platform name="ios">
        <podspec>
            <pods>
                <pod name="GoogleTagManager" spec="~> 7.0" />
            </pods>
        </podspec>
        <resource-file src="resources/container/GTM-KLBN64W6.json" target="container/GTM-KLBN64W6.json" />
        <hook type="after_prepare" src="hooks/copyContainer_iOS.js" />
    </platform>  
</plugin>
